{
  "manifest_version": 3,
  "name": "Elyxora Tab",
  "version": "1.0.0",
  "description": "Visual bookmarks and dashboard for your new tab",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}